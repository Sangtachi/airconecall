# 카탈로그·주문·기사 API (airconeCallServer). 예: http://127.0.0.1:4000 (끝 슬래시 없음)
VITE_API_BASE_URL=

# vite dev 서버가 같은 출처로 /api/* 를 Nest 로 넘길 프록시 대상 (기본 127.0.0.1:4000 또는 위 URL)
# 브라우저에서 localhost:5173 으로 띄울 때 /api/admin/… 404 나면 프록시 대상 또는 VITE_API_BASE_URL 확인
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:4000

# 로컬/비프로덕션 백엔드는 모의 결제 가능(기본). 운영(production)·DISABLE_MOCK_PAYMENTS 차단 참고 서버 README.

# 구버전 접수 API (예정) — 카탈로그와 무관하면 비워두면 됨
# submitRequest 에서 추후 연결

# 공개 사이트 URL(끝 슬래시 없이). canonical·OG·structured data·robots/sitemap 에 주입합니다.
VITE_SEO_ORIGIN=
