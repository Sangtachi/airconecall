# 새 클론 후: 필요 시 `.env.development.local` 만 추가하면 됩니다.
# 기본 로컬값은 저장소의 `.env.development` 참고.

# ── 모드 A: 로컬 Nest + Vite (권장) ──
# 1) airconeCallServer `npm run dev` + airconeCall `npm run dev` 또는 `npm run dev:stack`
# 2) 브라우저가 localhost / 127.0.0.1 로 열렸을 때는 VITE 비우면 코드가 알아서 Nest :4000 으로 직접 요청함.
#    (같은 PC에서 http://192.168.x.x:5173 으로 열면 `/api` 프록시에 의존 — VITE_DEV_API_PROXY_TARGET 확인)

# ── 모드 B: 원격 API만 ──
# .env.development.local 에 호스트만(끝 슬래시·/api 없음):
# VITE_API_BASE_URL=https://staging-or-prod-host.example.com

# 카탈로그·주문·기사 API (직접 URL로 부를 때). 예: http://127.0.0.1:4000
# 비우면 브라우저는 같은 출처 `/api/...` (Vite 프록시 또는 배포 호스트 규칙)
VITE_API_BASE_URL=

# Vite 가 /api/* 를 넘길 Nest 주소 (기본은 .env.development 에 있음)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:4000

# 로컬에서 Cannot POST /api/... 보통 원인:
# - Nest 미기동 / 포트 다름 → VITE_DEV_API_PROXY_TARGET 맞추기 또는 dev:stack 사용
# - VITE_API_BASE_URL 끝에 `/api` 붙임 → /api 가 이중으로 붙음

# 로컬/비프로덕션 백엔드 모의결제 등은 서버 README 참고.

# 공개 사이트 URL (.env.development 기본값: http://localhost:5173)
# VITE_SEO_ORIGIN=
